# ====================
# Secrets (CFW Secrets)
# ====================

# Kaggle API Token
# Get your API token from https://www.kaggle.com/settings
# Click "Create New Token" under the API section
KAGGLE_API_TOKEN=your_kaggle_api_token

# Slack Webhook URL (optional)
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord Webhook URL (optional)
# Create a webhook in Discord: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# Google Service Account Key (required for spreadsheet provider)
# JSON string of the service account credentials
# GOOGLE_SERVICE_ACCOUNT_KEY={"client_email":"...","private_key":"..."}

# ====================
# Config Provider
# ====================

# Select where operational config (e.g. member IDs) comes from
# 'env' = environment variables (default)
# 'spreadsheet' = Google Spreadsheet
CONFIG_PROVIDER=env

# ====================
# Config: env provider
# ====================

# Target User IDs
# Comma-separated list of Kaggle user IDs (usernames) to track
TARGET_USER_IDS=user1,user2,user3

# ====================
# Config: spreadsheet provider
# ====================

# Google Spreadsheet ID
# The ID from the spreadsheet URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
# SPREADSHEET_ID=your_spreadsheet_id

# Sheet name (optional, default: Sheet1)
# SHEET_NAME=Sheet1
